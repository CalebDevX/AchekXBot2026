# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Get your session key from: https://session.achek.com.ng
# Format: ACHEK~XXXXXX   (multiple sessions: ACHEK~KEY1,ACHEK~KEY2)
SESSION=ACHEK~YourKeyHere

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=./bot.db

# PostgreSQL (optional, for cloud platforms that provide it):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── BOT SETTINGS ─────────────────────────────────────────────────────────────
BOT_NAME=AchekBot
PREFIX=.
HANDLERS=.,
MODE=private
SUDO=2348000000000

# ─── OPTIONAL FEATURES ────────────────────────────────────────────────────────
# Gemini AI chatbot (get free key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Auto-reply to calls (true/false)
REJECT_CALL=true

# Read all messages automatically (true/false)
READ_MESSAGES=false

# Show react emoji on commands (true/false)
CMD_REACTION=true

# Disable the online startup message (true/false)
DISABLE_START_MESSAGE=true

# ─── DEPLOYMENT ───────────────────────────────────────────────────────────────
PORT=5000
